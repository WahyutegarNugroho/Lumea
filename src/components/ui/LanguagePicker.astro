---
import { Languages } from 'lucide-react';
import { getLocalizedPath, getLocaleFromPath } from '../../lib/i18n';

const languages = ['en', 'id', 'es'];
const currentPath = Astro.url.pathname;
const currentLang = getLocaleFromPath(currentPath);

// Cycle logic
const currentIndex = languages.indexOf(currentLang);
const nextIndex = (currentIndex + 1) % languages.length;
const nextLang = languages[nextIndex];

// Clean path helper
const segments = currentPath.split('/').filter(Boolean);
const cleanPath = ['id', 'es'].includes(segments[0]) 
  ? '/' + segments.slice(1).join('/') 
  : currentPath;

const nextPath = getLocalizedPath(cleanPath, nextLang);
---

<!-- VERSI COMPACT PUTIH: SATU KLIK LANGSUNG GANTI -->
<a 
  href={nextPath}
  class="flex items-center gap-2 px-3 py-1.5 bg-white dark:bg-zinc-800 border border-zinc-200 dark:border-zinc-700 rounded-full text-xs font-bold text-zinc-600 dark:text-zinc-400 hover:border-zinc-900 dark:hover:border-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-200 transition-all active:scale-95 shadow-sm"
  id="lang-cycler-v3"
  title={`Next: ${nextLang.toUpperCase()}`}
>
  <Languages size={14} className="text-zinc-500 dark:text-zinc-400" />
  <span class="uppercase tracking-tight">{currentLang}</span>
  <span class="text-zinc-300 dark:text-zinc-600">→</span>
  <span class="uppercase tracking-tight text-zinc-500 dark:text-zinc-400">{nextLang}</span>
</a>
