---
import { Languages } from 'lucide-react';
import { getLocalizedPath } from '../../lib/i18n';

const languages = [
  { code: 'en', name: 'English', flag: '🇺🇸' },
  { code: 'id', name: 'Bahasa Indonesia', flag: '🇮🇩' },
  { code: 'es', name: 'Español', flag: '🇪🇸' },
];

const currentLang = Astro.currentLocale || 'en';

// Get the current path without the locale prefix
const pathname = Astro.url.pathname;
const pathSegments = pathname.split('/').filter(Boolean);
let cleanPath = pathname;

if (['id', 'es'].includes(pathSegments[0])) {
  cleanPath = '/' + pathSegments.slice(1).join('/');
}
---

<div class="relative group">
  <button class="flex items-center gap-2 px-3 py-1.5 bg-white border border-zinc-200 rounded-xl text-xs font-bold text-zinc-600 hover:border-zinc-900 hover:text-zinc-900 transition-all">
    <Languages size={14} />
    <span class="uppercase">{currentLang}</span>
  </button>
  
  <div class="absolute right-0 top-full mt-2 w-48 bg-white border border-zinc-200 rounded-2xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50 overflow-hidden">
    {languages.map((l) => (
      <a 
        href={getLocalizedPath(cleanPath, l.code)}
        class={`flex items-center gap-3 px-4 py-3 text-sm font-medium hover:bg-zinc-50 transition-colors ${currentLang === l.code ? 'text-zinc-900 bg-zinc-50' : 'text-zinc-500'}`}
      >
        <span>{l.flag}</span>
        {l.name}
      </a>
    ))}
  </div>
</div>
