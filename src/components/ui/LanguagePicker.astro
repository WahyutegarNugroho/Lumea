---
import { Languages } from 'lucide-react';
import { getLocalizedPath, getLocaleFromPath } from '../../lib/i18n';

const languages = ['en', 'id', 'es'];
const currentPath = Astro.url.pathname;
const currentLang = getLocaleFromPath(currentPath);

// Cycle logic
const currentIndex = languages.indexOf(currentLang);
const nextIndex = (currentIndex + 1) % languages.length;
const nextLang = languages[nextIndex];

// Clean path helper
const segments = currentPath.split('/').filter(Boolean);
const cleanPath = ['id', 'es'].includes(segments[0]) 
  ? '/' + segments.slice(1).join('/') 
  : currentPath;

const nextPath = getLocalizedPath(cleanPath, nextLang);
---

<!-- VERSI TERBARU: SATU KLIK LANGSUNG GANTI -->
<a 
  href={nextPath}
  class="flex items-center gap-3 px-4 py-2 bg-zinc-900 text-white rounded-2xl text-xs font-bold hover:bg-zinc-800 transition-all active:scale-95 shadow-lg shadow-zinc-200"
  id="lang-cycler-v2"
>
  <Languages size={16} class="text-zinc-400" />
  <div class="flex flex-col items-start leading-none">
    <span class="text-[10px] text-zinc-500 uppercase mb-0.5">Lang</span>
    <span class="uppercase text-sm">{currentLang} → {nextLang}</span>
  </div>
</a>
