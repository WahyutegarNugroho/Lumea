---
import { Languages } from 'lucide-react';
import { getLocalizedPath, getLocaleFromPath } from '../../lib/i18n';

const languages = ['en', 'id', 'es'];
const currentLang = getLocaleFromPath(Astro.url.pathname);

// Calculate next language in the cycle
const currentIndex = languages.indexOf(currentLang);
const nextIndex = (currentIndex + 1) % languages.length;
const nextLang = languages[nextIndex];

// Get clean path (without current locale)
const pathname = Astro.url.pathname;
const getCleanPath = (path: string) => {
  const segments = path.split('/').filter(Boolean);
  if (['id', 'es'].includes(segments[0])) {
    return '/' + segments.slice(1).join('/');
  }
  return path;
};

const nextPath = getLocalizedPath(getCleanPath(pathname), nextLang);
---

<a 
  href={nextPath}
  class="flex items-center gap-2 px-3 py-1.5 bg-white border border-zinc-200 rounded-xl text-xs font-bold text-zinc-600 hover:border-zinc-900 hover:text-zinc-900 transition-all active:scale-95 shadow-sm"
  title={`Switch to ${nextLang.toUpperCase()}`}
>
  <Languages size={14} className="text-zinc-400" />
  <span class="uppercase w-4 text-center">{currentLang}</span>
  <div class="w-px h-3 bg-zinc-200 mx-0.5"></div>
  <span class="uppercase text-[10px] text-zinc-400 font-medium">Next: {nextLang}</span>
</a>
