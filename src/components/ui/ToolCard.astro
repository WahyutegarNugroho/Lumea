---
import { type LucideIcon, ArrowRight } from 'lucide-react';
import { useTranslations, type Locale, getLocalizedPath } from '../../lib/i18n';

interface Props {
	title: string;
	description: string;
	href: string;
	icon: LucideIcon;
	color: 'blue' | 'purple' | 'emerald' | 'orange' | 'rose' | 'amber';
	isExternal?: boolean;
}

const { title, description, href, icon: Icon, color, isExternal = false } = Astro.props;

const lang = (Astro.currentLocale || 'en') as Locale;
const t = useTranslations(lang);

const colorMap: Record<string, { bg: string; text: string }> = {
	blue: { bg: 'bg-blue-100 dark:bg-blue-900/40', text: 'text-blue-600 dark:text-blue-400' },
	purple: { bg: 'bg-purple-100 dark:bg-purple-900/40', text: 'text-purple-600 dark:text-purple-400' },
	emerald: { bg: 'bg-emerald-100 dark:bg-emerald-900/40', text: 'text-emerald-600 dark:text-emerald-400' },
	rose: { bg: 'bg-rose-100 dark:bg-rose-900/40', text: 'text-rose-600 dark:text-rose-400' },
	amber: { bg: 'bg-amber-100 dark:bg-amber-900/40', text: 'text-amber-600 dark:text-amber-400' },
	orange: { bg: 'bg-orange-100 dark:bg-orange-900/40', text: 'text-orange-600 dark:text-orange-400' },
};

const classes = colorMap[color] || colorMap.blue;
---

<a href={getLocalizedPath(href, lang)} class="group relative block p-6 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-2xl transition-all duration-300 hover:shadow-xl hover:shadow-zinc-200/50 dark:hover:shadow-zinc-900/50 hover:-translate-y-1 overflow-hidden">
	<!-- Decorative Background Gradient -->
	<div class={`absolute -right-4 -top-4 w-24 h-24 blur-3xl opacity-0 transition-opacity duration-500 group-hover:opacity-20 ${color === 'blue' ? 'bg-blue-400' : color === 'purple' ? 'bg-purple-400' : color === 'emerald' ? 'bg-emerald-400' : color === 'orange' ? 'bg-orange-400' : color === 'rose' ? 'bg-rose-400' : 'bg-amber-400'}`}></div>

	<div class="relative z-10">
		<div class="flex items-center justify-between mb-4">
			<div class={`inline-flex items-center justify-center w-12 h-12 rounded-xl transition-colors duration-300 ${classes.bg} ${classes.text}`}>
				<Icon size={24} strokeWidth={2} />
			</div>
			{isExternal && (
				<span class="px-2 py-1 bg-zinc-100 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400 text-[10px] font-black uppercase tracking-widest rounded-md border border-zinc-200 dark:border-zinc-700 group-hover:bg-zinc-900 dark:group-hover:bg-white group-hover:text-white dark:group-hover:text-zinc-900 group-hover:border-zinc-900 dark:group-hover:border-white transition-all">
					{t('ui.external_label')}
				</span>
			)}
		</div>
		
		<h3 class="text-lg font-bold text-zinc-900 dark:text-zinc-50 mb-2 font-outfit group-hover:text-zinc-900 dark:group-hover:text-zinc-50 transition-colors">
			{title}
		</h3>
		
		<p class="text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed mb-4 group-hover:text-zinc-600 dark:group-hover:text-zinc-300 transition-colors">
			{description}
		</p>
		
		<div class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-900 dark:group-hover:text-zinc-50 transition-colors">
			{t('nav.tools')}
			<ArrowRight size={14} className="transition-transform group-hover:translate-x-1" />
		</div>
	</div>
</a>
