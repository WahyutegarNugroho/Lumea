---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ui/ToolCard.astro';
import { ALL_TOOLS } from '../lib/tools';
import lucide from 'lucide-react';
const { FileText, Image: ImageIcon, Type, Code, Clock, Heart } = lucide;

const pdfTools = ALL_TOOLS.filter(t => t.category === 'pdf');
const imageTools = ALL_TOOLS.filter(t => t.category === 'image');
const textTools = ALL_TOOLS.filter(t => t.category === 'text');
const devTools = ALL_TOOLS.filter(t => t.category === 'dev');

import { useTranslations, translations, type Locale } from '../lib/i18n';
const lang = (Astro.currentLocale || 'en') as Locale;
const t = useTranslations(lang);
---

<BaseLayout>
	<!-- Hero Section -->
	<section class="relative pt-20 pb-32 overflow-hidden">
		<!-- Background Glows -->
		<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-6xl h-[500px] bg-zinc-100/50 dark:bg-zinc-900/50 rounded-[100%] blur-3xl -z-10"></div>
		
		<div class="container mx-auto px-4 text-center">
			<div class="inline-flex items-center gap-2 px-3 py-1 bg-zinc-900 text-white rounded-full text-xs font-bold uppercase tracking-widest mb-8 animate-fade-in">
				<span class="relative flex h-2 w-2">
					<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
					<span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-400"></span>
				</span>
				{t('badge.browser_only')}
			</div>
			
			<h1 class="text-5xl md:text-7xl font-bold font-outfit tracking-tight text-zinc-900 dark:text-zinc-50 mb-6 max-w-4xl mx-auto leading-[1.1]">
				{t('hero.title')} <span class="text-zinc-500 dark:text-zinc-400">{t('hero.subtitle')}</span>
			</h1>
			
			<p class="text-xl text-zinc-500 dark:text-zinc-400 max-w-2xl mx-auto mb-10 leading-relaxed">
				{t('hero.description')}
			</p>
			
			<div class="flex flex-wrap justify-center gap-4 max-w-5xl mx-auto">
				<a href="#pdf" class="group px-6 py-4 bg-zinc-900 dark:bg-zinc-100 text-white dark:text-zinc-900 rounded-2xl font-bold transition-all hover:bg-zinc-800 dark:hover:bg-white hover:-translate-y-1 hover:shadow-xl hover:shadow-rose-500/10 flex items-center gap-3 border border-zinc-800 dark:border-zinc-200">
					<div class="w-8 h-8 bg-white dark:bg-zinc-900/10 dark:bg-zinc-900/10 rounded-lg flex items-center justify-center text-rose-400 dark:text-rose-500 group-hover:scale-110 transition-transform">
						<FileText size={18} />
					</div>
					{t('hero.cta.pdf')}
				</a>
				<a href="#image" class="group px-6 py-4 bg-white dark:bg-zinc-900 text-zinc-900 dark:text-zinc-50 border border-zinc-200 dark:border-zinc-800 rounded-2xl font-bold transition-all hover:bg-zinc-50 dark:hover:bg-zinc-800 dark:bg-zinc-950 dark:hover:bg-zinc-800 hover:-translate-y-1 hover:shadow-xl hover:shadow-blue-500/10 flex items-center gap-3">
					<div class="w-8 h-8 bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-lg flex items-center justify-center group-hover:scale-110 transition-transform">
						<ImageIcon size={18} />
					</div>
					{t('hero.cta.image')}
				</a>
				<a href="#text" class="group px-6 py-4 bg-white dark:bg-zinc-900 text-zinc-900 dark:text-zinc-50 border border-zinc-200 dark:border-zinc-800 rounded-2xl font-bold transition-all hover:bg-zinc-50 dark:hover:bg-zinc-800 dark:bg-zinc-950 dark:hover:bg-zinc-800 hover:-translate-y-1 hover:shadow-xl hover:shadow-emerald-500/10 flex items-center gap-3">
					<div class="w-8 h-8 bg-emerald-50 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400 rounded-lg flex items-center justify-center group-hover:scale-110 transition-transform">
						<Type size={18} />
					</div>
					{t('hero.cta.text')}
				</a>
				<a href="#dev" class="group px-6 py-4 bg-white dark:bg-zinc-900 text-zinc-900 dark:text-zinc-50 border border-zinc-200 dark:border-zinc-800 rounded-2xl font-bold transition-all hover:bg-zinc-50 dark:hover:bg-zinc-800 dark:bg-zinc-950 dark:hover:bg-zinc-800 hover:-translate-y-1 hover:shadow-xl hover:shadow-purple-500/10 flex items-center gap-3">
					<div class="w-8 h-8 bg-purple-50 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 rounded-lg flex items-center justify-center group-hover:scale-110 transition-transform">
						<Code size={18} />
					</div>
					{t('hero.cta.dev')}
				</a>
			</div>
		</div>
	</section>

	<div class="container mx-auto px-4 pb-32 space-y-24">
		<!-- Favorites Section -->
		<section id="favorite-tools-section" class="hidden scroll-mt-24">
			<div class="flex items-center gap-4 mb-10">
				<div class="w-12 h-12 bg-rose-100 dark:bg-rose-900/40 text-rose-600 dark:text-rose-400 rounded-2xl flex items-center justify-center">
					<Heart size={24} className="fill-rose-500" />
				</div>
				<div>
					<h2 class="text-3xl font-bold font-outfit text-zinc-900 dark:text-zinc-50">{t('ui.favorites') || 'Favorites'}</h2>
					<p class="text-zinc-500 dark:text-zinc-400">{t('ui.favorites_desc') || 'Your most loved tools'}</p>
				</div>
			</div>
			<div 
				id="favorite-tools-grid" 
				data-label={t('ui.favorites') || 'Favorite'} 
				data-translations={JSON.stringify(translations[lang])}
				data-lang={lang}
			 class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"
			>
				<!-- Injected via script -->
			</div>
		</section>

		<!-- Recent Tools Section -->
		<section id="recent-tools-section" class="hidden scroll-mt-24">
			<div class="flex items-center gap-4 mb-10">
				<div class="w-12 h-12 bg-zinc-100 dark:bg-zinc-800 text-zinc-900 dark:text-zinc-50 rounded-2xl flex items-center justify-center">
					<Clock size={24} />
				</div>
				<div>
					<h2 class="text-3xl font-bold font-outfit text-zinc-900 dark:text-zinc-50">{t('recent.title')}</h2>
					<p class="text-zinc-500 dark:text-zinc-400">{t('recent.subtitle')}</p>
				</div>
			</div>
			<div 
				id="recent-tools-grid" 
				data-label={t('recent.tag')} 
				data-translations={JSON.stringify(translations[lang])}
				data-lang={lang}
			 class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"
			>
				<!-- Injected via script -->
			</div>
		</section>
		
		<!-- PDF Section -->
		<section id="pdf" class="scroll-mt-24">
			<div class="flex items-center gap-4 mb-10">
				<div class="w-12 h-12 bg-rose-100 dark:bg-rose-900/30 text-rose-600 dark:text-rose-400 rounded-2xl flex items-center justify-center">
					<FileText size={24} />
				</div>
				<div>
					<h2 class="text-3xl font-bold font-outfit text-zinc-900 dark:text-zinc-50">{t('cat.pdf')}</h2>
					<p class="text-zinc-500 dark:text-zinc-400">{t('cat.pdf.desc')}</p>
				</div>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
				{pdfTools.map(tool => (
					<ToolCard 
						{...tool}
						title={t(`tool.${tool.id}.title`)}
						description={t(`tool.${tool.id}.desc`)}
						color="rose" 
					/>
				))}
			</div>
		</section>

		<!-- Image Section -->
		<section id="image" class="scroll-mt-24">
			<div class="flex items-center gap-4 mb-10">
				<div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 rounded-2xl flex items-center justify-center">
					<ImageIcon size={24} />
				</div>
				<div>
					<h2 class="text-3xl font-bold font-outfit text-zinc-900 dark:text-zinc-50">{t('cat.image')}</h2>
					<p class="text-zinc-500 dark:text-zinc-400">{t('cat.image.desc')}</p>
				</div>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
				{imageTools.map(tool => (
					<ToolCard 
						{...tool}
						title={t(`tool.${tool.id}.title`)}
						description={t(`tool.${tool.id}.desc`)}
						color="blue" 
					/>
				))}
			</div>
		</section>

		<!-- Text Section -->
		<section id="text" class="scroll-mt-24">
			<div class="flex items-center gap-4 mb-10">
				<div class="w-12 h-12 bg-emerald-100 dark:bg-emerald-900/30 text-emerald-600 dark:text-emerald-400 rounded-2xl flex items-center justify-center">
					<Type size={24} />
				</div>
				<div>
					<h2 class="text-3xl font-bold font-outfit text-zinc-900 dark:text-zinc-50">{t('cat.text')}</h2>
					<p class="text-zinc-500 dark:text-zinc-400">{t('cat.text.desc')}</p>
				</div>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
				{textTools.map(tool => (
					<ToolCard 
						{...tool}
						title={t(`tool.${tool.id}.title`)}
						description={t(`tool.${tool.id}.desc`)}
						color="emerald" 
					/>
				))}
			</div>
		</section>

		<!-- Developer Section -->
		<section id="dev" class="scroll-mt-24">
			<div class="flex items-center gap-4 mb-10">
				<div class="w-12 h-12 bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 rounded-2xl flex items-center justify-center">
					<Code size={24} />
				</div>
				<div>
					<h2 class="text-3xl font-bold font-outfit text-zinc-900 dark:text-zinc-50">{t('cat.dev')}</h2>
					<p class="text-zinc-500 dark:text-zinc-400">{t('cat.dev.desc')}</p>
				</div>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
				{devTools.map(tool => (
					<ToolCard 
						{...tool}
						title={t(`tool.${tool.id}.title`)}
						description={t(`tool.${tool.id}.desc`)}
						color="purple" 
					/>
				))}
			</div>
		</section>
	</div>

	<!-- Trust Banner -->
	<section class="bg-zinc-900 py-24 overflow-hidden relative">
		<div class="absolute top-0 right-0 w-96 h-96 bg-zinc-800 rounded-full blur-3xl opacity-50 -mr-48 -mt-48"></div>
		<div class="container mx-auto px-4 relative z-10">
			<div class="max-w-3xl">
				<h2 class="text-3xl md:text-5xl font-bold font-outfit text-white mb-6">
					{t('trust.title')}
				</h2>
				<p class="text-zinc-500 dark:text-zinc-400 text-lg mb-8">
					{t('trust.description')}
				</p>
				<div class="flex flex-wrap gap-8">
					<div class="flex flex-col">
						<span class="text-white font-bold text-3xl mb-1">0</span>
						<span class="text-zinc-500 dark:text-zinc-400 text-sm uppercase tracking-wider">{t('trust.uploaded')}</span>
					</div>
					<div class="flex flex-col">
						<span class="text-white font-bold text-3xl mb-1">100%</span>
						<span class="text-zinc-500 dark:text-zinc-400 text-sm uppercase tracking-wider">{t('trust.client')}</span>
					</div>
					<div class="flex flex-col">
						<span class="text-white font-bold text-3xl mb-1">∞</span>
						<span class="text-zinc-500 dark:text-zinc-400 text-sm uppercase tracking-wider">{t('trust.free')}</span>
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>

<script>
import { ALL_TOOLS } from '../lib/tools';
import { getRecentTools } from '../lib/recentTools';

	function updateRecentTools() {
		const recentIds = getRecentTools();
		const section = document.getElementById('recent-tools-section');
		const grid = document.getElementById('recent-tools-grid');

		if (recentIds.length > 0 && section && grid) {
			const tData = JSON.parse(grid.dataset.translations || '{}');
			section.classList.remove('hidden');
			const recentTools = recentIds
				.map((id: string) => ALL_TOOLS.find(tool => tool.id === id))
				.filter((tool: any) => tool != null)
				.slice(0, 3);

			grid.innerHTML = recentTools.map((tool: any) => {
				const currentLang = grid.dataset.lang || 'en';
				const href = currentLang === 'en' ? tool.href : `/${currentLang}${tool.href}`;
				const externalBadge = tool.isExternal 
					? `<span class="px-2 py-1 bg-zinc-100 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400 text-[10px] font-black uppercase tracking-widest rounded-md border border-zinc-200 dark:border-zinc-800 group-hover:bg-zinc-900 group-hover:text-white group-hover:border-zinc-900 transition-all">${tData['ui.external_label'] || 'External'}</span>`
					: '';
				return `
					<a href="${href}" class="group relative block p-6 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-2xl transition-all duration-300 hover:shadow-xl hover:shadow-zinc-200/50 dark:hover:shadow-zinc-900/50 hover:-translate-y-1 overflow-hidden">
						<div class="relative z-10">
							<div class="flex items-center justify-between mb-4">
								<div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-zinc-100 dark:bg-zinc-800 text-zinc-900 dark:text-zinc-50 group-hover:bg-zinc-900 dark:group-hover:bg-white dark:bg-zinc-900 group-hover:text-white dark:group-hover:text-zinc-900 dark:text-zinc-50 transition-colors">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
								</div>
								${externalBadge}
							</div>
							<h3 class="text-lg font-bold text-zinc-900 dark:text-zinc-50 mb-2 font-outfit">${tData['tool.' + tool.id + '.title'] || tool.title}</h3>
							<p class="text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed mb-4">${tData['tool.' + tool.id + '.desc'] || tool.description}</p>
							<div class="text-xs font-bold uppercase tracking-wider text-zinc-500 dark:text-zinc-400 group-hover:text-zinc-900 dark:text-zinc-50 dark:group-hover:text-zinc-50 transition-colors">${grid.dataset.label || 'Recently Used'}</div>
						</div>
					</a>
				`;
			}).join('');
		}
	}

	function updateFavoriteTools() {
		try {
			const favoriteIds = JSON.parse(localStorage.getItem('lumea_favorites') || '[]');
			const section = document.getElementById('favorite-tools-section');
			const grid = document.getElementById('favorite-tools-grid');

			if (section && grid) {
				if (favoriteIds.length > 0) {
					section.classList.remove('hidden');
					const tData = JSON.parse(grid.dataset.translations || '{}');
					const favoriteTools = favoriteIds
						.map((id: string) => ALL_TOOLS.find(tool => tool.id === id))
						.filter((tool: any) => tool != null);

					grid.innerHTML = favoriteTools.map((tool: any) => {
						const currentLang = grid.dataset.lang || 'en';
						const href = currentLang === 'en' ? tool.href : `/${currentLang}${tool.href}`;
						const externalBadge = tool.isExternal 
							? `<span class="px-2 py-1 bg-zinc-100 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400 text-[10px] font-black uppercase tracking-widest rounded-md border border-zinc-200 dark:border-zinc-800 group-hover:bg-zinc-900 dark:group-hover:bg-white group-hover:text-white dark:group-hover:text-zinc-900 transition-all">${tData['ui.external_label'] || 'External'}</span>`
							: '';
						return `
							<a href="${href}" class="group relative block p-6 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-2xl transition-all duration-300 hover:shadow-xl hover:shadow-zinc-200/50 dark:hover:shadow-zinc-900/50 hover:-translate-y-1 overflow-hidden">
								<div class="relative z-10">
									<div class="flex items-center justify-between mb-4">
										<button class="favorite-remove-btn inline-flex items-center justify-center w-12 h-12 rounded-xl bg-rose-50 dark:bg-rose-900/30 text-rose-500 dark:text-rose-400 hover:bg-rose-500 dark:hover:bg-rose-500 hover:text-white dark:hover:text-white transition-colors cursor-pointer" data-id="${tool.id}" aria-label="Remove from favorites">
											<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
										</button>
										${externalBadge}
									</div>
									<h3 class="text-lg font-bold text-zinc-900 dark:text-zinc-50 mb-2 font-outfit">${tData['tool.' + tool.id + '.title'] || tool.title}</h3>
									<p class="text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed mb-4">${tData['tool.' + tool.id + '.desc'] || tool.description}</p>
									<div class="text-xs font-bold uppercase tracking-wider text-rose-500 dark:text-rose-400 group-hover:text-rose-600 dark:group-hover:text-rose-300 transition-colors">${grid.dataset.label || 'Favorite'}</div>
								</div>
							</a>
						`;
					}).join('');

					grid.querySelectorAll('.favorite-remove-btn').forEach(btn => {
						btn.addEventListener('click', (e) => {
							e.preventDefault();
							e.stopPropagation();
							const toolId = btn.getAttribute('data-id');
							if (toolId) {
								const currentFavorites = JSON.parse(localStorage.getItem('lumea_favorites') || '[]');
								const updatedFavorites = currentFavorites.filter((id: string) => id !== toolId);
								localStorage.setItem('lumea_favorites', JSON.stringify(updatedFavorites));
								window.dispatchEvent(new Event('lumea:favorites-updated'));
							}
						});
					});
				} else {
					section.classList.add('hidden');
				}
			}
		} catch {}
	}

	// Run on initial load and after transitions
	document.addEventListener('astro:page-load', () => {
		updateRecentTools();
		updateFavoriteTools();
	});
	window.addEventListener('lumea:favorites-updated', updateFavoriteTools);
</script>


