---
import { getI18nPaths } from '../../../lib/routing';
export const getStaticPaths = getI18nPaths;
const { lang: langParam } = Astro.params;
const lang = langParam || 'en';

import ToolLayout from '../../../layouts/ToolLayout.astro';
import BarcodeGenerator from '../../../components/tools/BarcodeGenerator';
import { useTranslations } from '../../../lib/i18n';
const t = useTranslations(lang);
---

<ToolLayout 
	title={t('tool.barcode-generator.title')}
	description={t('tool.barcode-generator.desc')}
	category="image"
	toolId="barcode-generator"
>
	<BarcodeGenerator client:only="react" lang={lang} />

	<div slot="guide">
		<h3 class="text-2xl font-bold mb-6">{t('ui.how_to')} {t('tool.barcode-generator.title')}</h3>
		<p class="text-zinc-500 mb-12">{t('guide.barcode-generator.p1')}</p>
		
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
			<div class="bg-white p-8 rounded-3xl border border-zinc-100 shadow-sm">
				<div class="w-12 h-12 bg-zinc-100 rounded-2xl flex items-center justify-center text-zinc-900 mb-6">
					<span class="font-bold">01</span>
				</div>
				<h4 class="text-lg font-bold mb-3">{t('guide.barcode-generator.s1_t')}</h4>
				<p class="text-zinc-500 text-sm leading-relaxed">{t('guide.barcode-generator.s1_d')}</p>
			</div>
			
			<div class="bg-white p-8 rounded-3xl border border-zinc-100 shadow-sm">
				<div class="w-12 h-12 bg-zinc-100 rounded-2xl flex items-center justify-center text-zinc-900 mb-6">
					<span class="font-bold">02</span>
				</div>
				<h4 class="text-lg font-bold mb-3">{t('guide.barcode-generator.s2_t')}</h4>
				<p class="text-zinc-500 text-sm leading-relaxed">{t('guide.barcode-generator.s2_d')}</p>
			</div>
			
			<div class="bg-white p-8 rounded-3xl border border-zinc-100 shadow-sm">
				<div class="w-12 h-12 bg-zinc-100 rounded-2xl flex items-center justify-center text-zinc-900 mb-6">
					<span class="font-bold">03</span>
				</div>
				<h4 class="text-lg font-bold mb-3">{t('guide.barcode-generator.s3_t')}</h4>
				<p class="text-zinc-500 text-sm leading-relaxed">{t('guide.barcode-generator.s3_d')}</p>
			</div>
		</div>
	</div>
</ToolLayout>
