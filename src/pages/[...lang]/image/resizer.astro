---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'id' } },
    { params: { lang: 'es' } },
  ];
}

const { lang: langParam } = Astro.params;
const lang = langParam || 'en';

import ToolLayout from '../../../layouts/ToolLayout.astro';
import ImageResizer from '../../../components/tools/ImageResizer';
import { useTranslations } from '../../../lib/i18n';
const t = useTranslations(lang as any);
---

<ToolLayout 
	title={t('tool.resizer.title')}
	description={t('tool.resizer.desc')}
	category="image"
	toolId="resizer"
>
	<ImageResizer client:only="react" lang={lang as any} />

	<div slot="guide">
		<h3>{t('guide.resizer.h1')}</h3>
		<p>{t('guide.resizer.p1')}</p>
		
		<ul>
			<li><strong>{t('guide.resizer.f1_t')}</strong> {t('guide.resizer.f1_d')}</li>
			<li><strong>{t('guide.resizer.f2_t')}</strong> {t('guide.resizer.f2_d')}</li>
			<li><strong>{t('guide.resizer.f3_t')}</strong> {t('guide.resizer.f3_d')}</li>
		</ul>
	</div>
</ToolLayout>
