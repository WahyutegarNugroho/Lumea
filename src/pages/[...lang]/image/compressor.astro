---
import { getI18nPaths } from '../../../lib/routing';
export const getStaticPaths = getI18nPaths;
const { lang: langParam } = Astro.params;
const lang = langParam || 'en';

import ToolLayout from '../../../layouts/ToolLayout.astro';
import ImageCompressor from '../../../components/tools/ImageCompressor';
import { useTranslations } from '../../../lib/i18n';
const t = useTranslations(lang);
---

<ToolLayout 
	title={t('tool.compressor.title')}
	description={t('tool.compressor.desc')}
	category="image"
	toolId="compressor"
>
	<ImageCompressor client:only="react" lang={lang} />

	<div slot="guide">
		<h3>{t('guide.compressor.h1')}</h3>
		<p>{t('guide.compressor.p1')}</p>
		
		<ul>
			<li><strong>{t('guide.compressor.f1_t')}</strong> {t('guide.compressor.f1_d')}</li>
			<li><strong>{t('guide.compressor.f2_t')}</strong> {t('guide.compressor.f2_d')}</li>
			<li><strong>{t('guide.compressor.f3_t')}</strong> {t('guide.compressor.f3_d')}</li>
		</ul>

		<h3>{t('guide.compressor.h2')}</h3>
		<p>{t('guide.compressor.p2')}</p>
	</div>
</ToolLayout>
