---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'id' } },
    { params: { lang: 'es' } },
  ];
}

const { lang: langParam } = Astro.params;
const lang = langParam || 'en';

import ToolLayout from '../../../layouts/ToolLayout.astro';
import SvgToPng from '../../../components/tools/SvgToPng';
import { useTranslations } from '../../../lib/i18n';
const t = useTranslations(lang as any);
---

<ToolLayout 
	title={t('tool.svg-to-png.title')}
	description={t('tool.svg-to-png.desc')}
	category="image"
	toolId="svg-to-png"
>
	<SvgToPng client:only="react" lang={lang as any} />

	<div slot="guide">
		<h3 class="text-2xl font-bold mb-6">How to convert SVG to PNG</h3>
		<p class="text-zinc-500 mb-12">Turn your vector graphics into high-quality raster images for web, social media, or presentations without losing sharpness.</p>
		
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
			<div class="bg-white p-8 rounded-3xl border border-zinc-100 shadow-sm">
				<div class="w-12 h-12 bg-zinc-100 rounded-2xl flex items-center justify-center text-zinc-900 mb-6">
					<span class="font-bold">01</span>
				</div>
				<h4 class="text-lg font-bold mb-3">Upload SVG</h4>
				<p class="text-zinc-500 text-sm leading-relaxed">Upload your .svg file. You will see an instant preview of your vector artwork in the dashboard.</p>
			</div>
			
			<div class="bg-white p-8 rounded-3xl border border-zinc-100 shadow-sm">
				<div class="w-12 h-12 bg-zinc-100 rounded-2xl flex items-center justify-center text-zinc-900 mb-6">
					<span class="font-bold">02</span>
				</div>
				<h4 class="text-lg font-bold mb-3">Set Resolution</h4>
				<p class="text-zinc-500 text-sm leading-relaxed">Adjust the width and height or use the scaling buttons (1x to 8x) to define your desired output size.</p>
			</div>
			
			<div class="bg-white p-8 rounded-3xl border border-zinc-100 shadow-sm">
				<div class="w-12 h-12 bg-zinc-100 rounded-2xl flex items-center justify-center text-zinc-900 mb-6">
					<span class="font-bold">03</span>
				</div>
				<h4 class="text-lg font-bold mb-3">Download PNG</h4>
				<p class="text-zinc-500 text-sm leading-relaxed">Click "Convert SVG to PNG" to render the image. Your high-quality PNG will be downloaded automatically.</p>
			</div>
		</div>
	</div>
</ToolLayout>
