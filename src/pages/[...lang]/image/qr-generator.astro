---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'id' } },
    { params: { lang: 'es' } },
  ];
}

const { lang: langParam } = Astro.params;
const lang = langParam || 'en';

import ToolLayout from '../../../layouts/ToolLayout.astro';
import QrGenerator from '../../../components/tools/QrGenerator';
import { useTranslations } from '../../../lib/i18n';
const t = useTranslations(lang as any);
---

<ToolLayout 
	title={t('tool.qr-generator.title')}
	description={t('tool.qr-generator.desc')}
	category="image"
	toolId="qr-generator"
>
	<QrGenerator client:only="react" lang={lang as any} />

	<div slot="guide">
		<h3>{t('guide.qr-generator.h1')}</h3>
		<p>{t('guide.qr-generator.p1')}</p>
		
		<ul>
			<li><strong>{t('guide.qr-generator.f1_t')}:</strong> {t('guide.qr-generator.f1_d')}</li>
			<li><strong>{t('guide.qr-generator.f2_t')}:</strong> {t('guide.qr-generator.f2_d')}</li>
			<li><strong>{t('guide.qr-generator.f3_t')}:</strong> {t('guide.qr-generator.f3_d')}</li>
		</ul>
	</div>
</ToolLayout>
