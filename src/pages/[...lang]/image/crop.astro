---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'id' } },
    { params: { lang: 'es' } },
  ];
}

const { lang: langParam } = Astro.params;
const lang = langParam || 'en';

import ToolLayout from '../../../layouts/ToolLayout.astro';
import ImageCropper from '../../../components/tools/ImageCropper';
import { useTranslations } from '../../../lib/i18n';
const t = useTranslations(lang as any);
---

<ToolLayout 
	title={t('tool.cropper.title')}
	description={t('tool.cropper.desc')}
	category="image"
	toolId="cropper"
>
	<ImageCropper client:only="react" lang={lang as any} />

	<div slot="guide">
		<h3>{t('guide.cropper.h1')}</h3>
		<p>{t('guide.cropper.p1')}</p>
		
		<ul>
			<li><strong>{t('guide.cropper.f1_t')}:</strong> {t('guide.cropper.f1_d')}</li>
			<li><strong>{t('guide.cropper.f2_t')}:</strong> {t('guide.cropper.f2_d')}</li>
		</ul>
	</div>
</ToolLayout>
