---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { BookOpen, ArrowLeft } from 'lucide-react';
import { useTranslations, getLocalizedPath } from '../../../lib/i18n';

export async function getStaticPaths() {
	const guides = await getCollection('guides');
	const langs = ['en', 'id', 'es'];
	
	return langs.flatMap(lang => {
		const prefix = lang + '/';
		return guides
			.filter(entry => entry.id.startsWith(prefix))
			.map((entry) => ({
				params: { lang: lang === 'en' ? undefined : lang, slug: entry.id.slice(prefix.length) },
				props: { html: entry.rendered?.html, entry, lang },
			}));
	});
}

const { entry, lang, html } = Astro.props;
const t = useTranslations(lang);
const toolId = entry.data.toolId as string;
import type { TranslationKey } from '../../../lib/i18n';
const guideH1 = t(`guide.${toolId}.h1` as TranslationKey) || entry.data.title;
const guideDesc = t(`guide.${toolId}.p1` as TranslationKey) || entry.data.description;
---

<BaseLayout 
	title={`${guideH1} - Lumea Blog`} 
	description={guideDesc}
>
	<div class="bg-zinc-50 dark:bg-zinc-950 border-b border-zinc-200 dark:border-zinc-800 py-16">
		<div class="container mx-auto px-4 max-w-4xl">
			<a href={getLocalizedPath('/blog', lang)} class="inline-flex items-center gap-2 text-sm font-bold text-zinc-400 hover:text-zinc-900 dark:text-zinc-50 transition-colors mb-8 uppercase tracking-widest">
				<ArrowLeft size={16} />
				{t('blog.back')}
			</a>
			
			<div class="inline-flex items-center gap-2 px-3 py-1 bg-zinc-200 text-zinc-600 dark:text-zinc-300 rounded-full text-xs font-bold uppercase tracking-widest mb-6">
				{t('cat.' + entry.data.category)}
			</div>
			
			<h1 class="text-4xl md:text-6xl font-bold font-outfit text-zinc-900 dark:text-zinc-50 mb-6 leading-tight">
				{guideH1}
			</h1>
			
			<p class="text-xl text-zinc-500 dark:text-zinc-400 leading-relaxed max-w-3xl">
				{guideDesc}
			</p>
		</div>
	</div>

	<article class="container mx-auto px-4 py-16 max-w-4xl">
		<div class="prose prose-zinc prose-lg max-w-none" set:html={html} />

		<div class="mt-16 pt-8 border-t border-zinc-100 dark:border-zinc-800 flex flex-col items-center text-center">
			<div class="w-16 h-16 bg-zinc-900 rounded-2xl flex items-center justify-center text-white mb-4">
				<BookOpen size={32} />
			</div>
			<h3 class="text-xl font-bold font-outfit text-zinc-900 dark:text-zinc-50">{t('blog.helpful')}</h3>
			<p class="text-zinc-500 dark:text-zinc-400 mb-6">{t('blog.share')}</p>
			
			<div class="flex gap-4">
				<a 
					href={getLocalizedPath(`/${entry.data.category}/${entry.data.toolId}`, lang)} 
				 class="px-8 py-4 bg-zinc-900 text-white rounded-2xl font-bold hover:scale-[1.02] transition-all shadow-xl shadow-zinc-200"
				>
					{t('blog.try_tool')}
				</a>
			</div>
		</div>
	</article>
</BaseLayout>
