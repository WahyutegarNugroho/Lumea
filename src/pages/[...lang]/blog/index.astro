---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'id' } },
    { params: { lang: 'es' } },
  ];
}

const { lang: langParam } = Astro.params;
const lang = (langParam || 'en') as any;

import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { BookOpen, ArrowRight } from 'lucide-react';
import { useTranslations, getLocalizedPath } from '../../../lib/i18n';

const t = useTranslations(lang);
const guides = await getCollection('guides');
---

<BaseLayout 
	title={`${t('blog.title')} - Lumea`} 
	description={t('blog.subtitle')}
>
	<div class="container mx-auto px-4 py-24">
		<div class="max-w-4xl mx-auto text-center mb-20">
			<h1 class="text-5xl md:text-7xl font-bold font-outfit text-zinc-900 mb-6">
				Lumea <span class="text-zinc-400">{t('nav.blog')}</span>
			</h1>
			<p class="text-xl text-zinc-500 leading-relaxed">
				{t('blog.subtitle')}
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-6xl mx-auto">
			{guides.map((guide: any) => (
				<a href={getLocalizedPath(`/blog/${guide.slug}`, lang)} class="group bg-white border border-zinc-200 rounded-3xl p-8 transition-all hover:shadow-2xl hover:shadow-zinc-200/50 hover:-translate-y-2">
					<div class="inline-flex items-center gap-2 px-3 py-1 bg-zinc-100 text-zinc-500 rounded-full text-[10px] font-bold uppercase tracking-widest mb-6 group-hover:bg-zinc-900 group-hover:text-white transition-colors">
						{guide.data.category}
					</div>
					
					<h2 class="text-2xl font-bold font-outfit text-zinc-900 mb-4 group-hover:text-zinc-900 leading-tight">
						{guide.data.title}
					</h2>
					
					<p class="text-zinc-500 mb-8 line-clamp-2">
						{guide.data.description}
					</p>
					
					<div class="flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-zinc-400 group-hover:text-zinc-900 transition-colors">
						{t('blog.read_guide')}
						<ArrowRight size={16} className="transition-transform group-hover:translate-x-2" />
					</div>
				</a>
			))}
		</div>

		{guides.length === 0 && (
			<div class="text-center py-20 bg-zinc-50 rounded-3xl border-2 border-dashed border-zinc-200">
				<BookOpen size={48} className="mx-auto text-zinc-300 mb-4" />
				<h3 class="text-xl font-bold text-zinc-900">{t('blog.coming_soon')}</h3>
				<p class="text-zinc-500">{t('blog.coming_soon_desc')}</p>
			</div>
		)}

		<!-- How it Works Section -->
		<div class="mt-32">
			<div class="text-center mb-16">
				<h2 class="text-3xl md:text-5xl font-bold font-outfit text-zinc-900 mb-4">{t('blog.how.title')}</h2>
				<p class="text-zinc-500 text-lg">{t('blog.how.subtitle')}</p>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
				<div class="bg-white border border-zinc-200 rounded-[2.5rem] p-10 text-center space-y-6 hover:shadow-xl hover:shadow-zinc-200/50 transition-all">
					<div class="w-16 h-16 bg-rose-50 text-rose-500 rounded-2xl flex items-center justify-center mx-auto">
						<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-cloud-off"><path d="m2 2 20 20"/><path d="M5.782 5.782A7 7 0 0 0 9 19h8.5a4.5 4.5 0 0 0 1.307-.193"/><path d="M21.532 16.5A4.5 4.5 0 0 0 17.5 10h-1.79A7.008 7.008 0 0 0 10 5.07"/></svg>
					</div>
					<div class="space-y-3">
						<h3 class="text-xl font-bold text-zinc-900">{t('blog.how.step1.title')}</h3>
						<p class="text-zinc-500 text-sm leading-relaxed">{t('blog.how.step1.text')}</p>
					</div>
				</div>

				<div class="bg-white border border-zinc-200 rounded-[2.5rem] p-10 text-center space-y-6 hover:shadow-xl hover:shadow-zinc-200/50 transition-all">
					<div class="w-16 h-16 bg-blue-50 text-blue-500 rounded-2xl flex items-center justify-center mx-auto">
						<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-cpu"><rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9" rx="1"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg>
					</div>
					<div class="space-y-3">
						<h3 class="text-xl font-bold text-zinc-900">{t('blog.how.step2.title')}</h3>
						<p class="text-zinc-500 text-sm leading-relaxed">{t('blog.how.step2.text')}</p>
					</div>
				</div>

				<div class="bg-white border border-zinc-200 rounded-[2.5rem] p-10 text-center space-y-6 hover:shadow-xl hover:shadow-zinc-200/50 transition-all">
					<div class="w-16 h-16 bg-emerald-50 text-emerald-500 rounded-2xl flex items-center justify-center mx-auto">
						<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
					</div>
					<div class="space-y-3">
						<h3 class="text-xl font-bold text-zinc-900">{t('blog.how.step3.title')}</h3>
						<p class="text-zinc-500 text-sm leading-relaxed">{t('blog.how.step3.text')}</p>
					</div>
				</div>
			</div>
		</div>

		<!-- Philosophy Section -->
		<div class="mt-32 max-w-4xl mx-auto">
			<div class="bg-gradient-to-br from-zinc-900 to-zinc-800 rounded-[3rem] p-12 text-center relative overflow-hidden shadow-2xl shadow-zinc-200">
				<!-- Decorative elements -->
				<div class="absolute top-0 left-0 w-full h-full opacity-20">
					<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-white rounded-full blur-[120px]"></div>
				</div>
				
				<div class="relative z-10 space-y-8">
					<div class="inline-flex items-center justify-center w-20 h-20 bg-white/10 rounded-3xl backdrop-blur-xl border border-white/20 text-white mb-2 shadow-inner">
						<span class="text-4xl">✨</span>
					</div>
					
					<div class="space-y-4">
						<h2 class="text-3xl md:text-5xl font-bold font-outfit text-white leading-tight">
							{t('blog.philosophy.title')}
						</h2>
						<p class="text-zinc-400 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto italic">
							“{t('blog.philosophy.text')}”
						</p>
					</div>

					<div class="pt-8 border-t border-white/10">
						<div class="flex flex-col items-center">
							<span class="text-zinc-500 text-sm font-bold tracking-[0.4em] mb-2 font-outfit uppercase">{t('blog.signature')}</span>
							<div class="h-0.5 w-16 bg-gradient-to-r from-transparent via-zinc-500 to-transparent opacity-50"></div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</BaseLayout>
