---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'id' } },
    { params: { lang: 'es' } },
  ];
}

const { lang: langParam } = Astro.params;
const lang = (langParam || 'en') as any;

import ToolLayout from '../../../layouts/ToolLayout.astro';
import { Copy, RefreshCw } from 'lucide-react';
import { useTranslations } from '../../../lib/i18n';
const t = useTranslations(lang);
---

<ToolLayout 
	title={t('tool.lorem-ipsum.title')}
	description={t('tool.lorem-ipsum.desc')}
	category="text"
	toolId="lorem-ipsum"
>
	<div class="space-y-6">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			<div>
				<label class="tool-label">{t('ui.amount')}</label>
				<input type="number" id="amount" value="3" min="1" max="50" class="tool-input" />
			</div>
			<div>
				<label class="tool-label">{t('ui.type')}</label>
				<select id="type" class="tool-input">
					<option value="paragraphs">{t('ui.paragraphs')}</option>
					<option value="sentences">{t('ui.sentences')}</option>
					<option value="words">{t('ui.words')}</option>
				</select>
			</div>
			<div class="flex items-end">
				<button id="generate-btn" class="tool-button-primary w-full flex items-center justify-center gap-2">
					<RefreshCw size={18} id="refresh-icon" />
					{t('ui.generate')}
				</button>
			</div>
		</div>

		<div>
			<label class="tool-label">{t('ui.result')}</label>
			<textarea 
				id="result-text" 
			 class="tool-input min-h-[300px] bg-white" 
				readonly
			></textarea>
		</div>

		<div class="flex pt-4">
			<button id="copy-btn" class="tool-button-secondary flex items-center gap-2" data-copied={t('ui.copied')}>
				<Copy size={18} />
				{t('ui.copy')}
			</button>
		</div>
	</div>

	<div slot="guide">
		<h3>{t('guide.lorem-ipsum.h1')}</h3>
		<p>{t('guide.lorem-ipsum.p1')}</p>
		
		<ul>
			<li><strong>{t('ui.paragraphs')}:</strong> {t('guide.lorem-ipsum.f1_d')}</li>
			<li><strong>{t('ui.sentences')}:</strong> {t('guide.lorem-ipsum.f2_d')}</li>
			<li><strong>{t('ui.words')}:</strong> {t('guide.lorem-ipsum.f3_d')}</li>
		</ul>
	</div>
</ToolLayout>

<script>
	const LOREM_TEXT = "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum. Curabitur pretium tincidunt lacus. Nulla gravida orci a odio. Nullam varius, turpis et commodo pharetra, est eros bibendum elit, nec luctus magna felis sollicitudin mauris. Integer in mauris eu nibh euismod gravida. Duis ac tellus et risus vulputate vehicula. Donec lobortis risus a elit. Etiam tempor. Ut ullamcorper, ligula eu tempor congue, eros est euismod turpis, id tincidunt sapien risus a quam. Maecenas fermentum consequat mi. Donec fermentum. Pellentesque malesuada nulla a mi. Duis sapien sem, aliquet nec, commodo eget, consequat quis, neque. Aliquam faucibus, elit ut dictum aliquet, felis nisl adipiscing sapien, sed malesuada diam lacus eget erat. Cras mollis scelerisque nunc. Donec vehicula cursus vestibulum. Mauris nisi magna, faucibus at, adipiscing eu, vehicula eget, enim.";

	const amountInput = document.getElementById('amount') as HTMLInputElement;
	const typeSelect = document.getElementById('type') as HTMLSelectElement;
	const resultText = document.getElementById('result-text') as HTMLTextAreaElement;
	const generateBtn = document.getElementById('generate-btn');
	const refreshIcon = document.getElementById('refresh-icon');
	const copyBtn = document.getElementById('copy-btn');

	function generate() {
		const amount = parseInt(amountInput.value);
		const type = typeSelect.value;
		let result = "";

		const words = LOREM_TEXT.split(' ');
		const sentences = LOREM_TEXT.split('. ');

		if (type === 'words') {
			result = words.slice(0, amount).join(' ');
		} else if (type === 'sentences') {
			for (let i = 0; i < amount; i++) {
				result += sentences[i % sentences.length] + ". ";
			}
		} else {
			for (let i = 0; i < amount; i++) {
				result += LOREM_TEXT + "\n\n";
			}
		}

		resultText.value = result.trim();
		
		// Animation
		refreshIcon?.classList.add('animate-spin');
		setTimeout(() => refreshIcon?.classList.remove('animate-spin'), 500);
	}

	generateBtn?.addEventListener('click', generate);
	
	copyBtn?.addEventListener('click', () => {
		resultText.select();
		navigator.clipboard.writeText(resultText.value);
		const originalHtml = copyBtn.innerHTML;
		const copiedText = copyBtn.getAttribute('data-copied') || '...';
		copyBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check"><polyline points="20 6 9 17 4 12"/></svg> ${copiedText}`;
		setTimeout(() => {
			copyBtn.innerHTML = originalHtml;
		}, 2000);
	});

	// Initial generate
	generate();
</script>
