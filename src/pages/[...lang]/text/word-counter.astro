---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'id' } },
    { params: { lang: 'es' } },
  ];
}

const { lang: langParam } = Astro.params;
const lang = (langParam || 'en') as any;

import ToolLayout from '../../../layouts/ToolLayout.astro';
import { Copy, Trash2 } from 'lucide-react';
import { useTranslations } from '../../../lib/i18n';
const t = useTranslations(lang);
---

<ToolLayout 
	title={t('tool.word-counter.title')}
	description={t('tool.word-counter.desc')}
	category="text"
	toolId="word-counter"
>
	<div class="space-y-6">
		<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
			<div class="bg-zinc-50 border border-zinc-100 rounded-2xl p-4 text-center">
				<div class="text-xs font-bold text-zinc-400 uppercase tracking-widest mb-1">{t('ui.words')}</div>
				<div id="word-count" class="text-3xl font-bold font-outfit text-zinc-900">0</div>
			</div>
			<div class="bg-zinc-50 border border-zinc-100 rounded-2xl p-4 text-center">
				<div class="text-xs font-bold text-zinc-400 uppercase tracking-widest mb-1">{t('ui.chars')}</div>
				<div id="char-count" class="text-3xl font-bold font-outfit text-zinc-900">0</div>
			</div>
			<div class="bg-zinc-50 border border-zinc-100 rounded-2xl p-4 text-center">
				<div class="text-xs font-bold text-zinc-400 uppercase tracking-widest mb-1">{t('ui.sentences')}</div>
				<div id="sentence-count" class="text-3xl font-bold font-outfit text-zinc-900">0</div>
			</div>
			<div class="bg-zinc-50 border border-zinc-100 rounded-2xl p-4 text-center">
				<div class="text-xs font-bold text-zinc-400 uppercase tracking-widest mb-1">{t('ui.reading_time')}</div>
				<div id="reading-time" class="text-3xl font-bold font-outfit text-zinc-900">0m</div>
			</div>
		</div>

		<div>
			<label for="text-input" class="tool-label">{t('ui.your_text')}</label>
			<textarea 
				id="text-input" 
			 class="tool-input min-h-[300px] font-mono text-sm" 
				placeholder={t('ui.placeholder_text')}
			></textarea>
		</div>

		<div class="flex flex-wrap gap-4 pt-4">
			<button 
				id="copy-btn" 
				class="tool-button-secondary flex items-center gap-2" 
				data-copied={t('ui.copied')}
				data-min-abbr={t('ui.minutes_abbr')}
			>
				<Copy size={18} />
				{t('ui.copy')}
			</button>
			<button id="clear-btn" class="tool-button-secondary flex items-center gap-2 text-rose-600 hover:bg-rose-50 hover:border-rose-100">
				<Trash2 size={18} />
				{t('ui.clear')}
			</button>
		</div>
	</div>

	<div slot="guide">
		<h3>{t('guide.word-counter.h1')}</h3>
		<p>{t('guide.word-counter.p1')}</p>
		
		<ul>
			<li><strong>{t('guide.word-counter.f1_t')}</strong> {t('guide.word-counter.f1_d')}</li>
			<li><strong>{t('guide.word-counter.f2_t')}</strong> {t('guide.word-counter.f2_d')}</li>
			<li><strong>{t('guide.word-counter.f3_t')}</strong> {t('guide.word-counter.f3_d')}</li>
		</ul>

		<h3>{t('guide.word-counter.h2')}</h3>
		<ol>
			<li>{t('guide.word-counter.s1')}</li>
			<li>{t('guide.word-counter.s2')}</li>
			<li>{t('guide.word-counter.s3')}</li>
		</ol>
	</div>
</ToolLayout>

<script>
	const textInput = document.getElementById('text-input') as HTMLTextAreaElement;
	const wordCountEl = document.getElementById('word-count');
	const charCountEl = document.getElementById('char-count');
	const sentenceCountEl = document.getElementById('sentence-count');
	const readingTimeEl = document.getElementById('reading-time');
	const copyBtn = document.getElementById('copy-btn');
	const clearBtn = document.getElementById('clear-btn');

	function updateCounts() {
		const text = textInput.value.trim();
		
		// Words
		const words = text ? text.split(/\s+/).length : 0;
		if (wordCountEl) wordCountEl.textContent = words.toString();
		
		// Characters
		const chars = textInput.value.length;
		if (charCountEl) charCountEl.textContent = chars.toString();
		
		// Sentences
		const sentences = text ? text.split(/[.!?]+/).filter(Boolean).length : 0;
		if (sentenceCountEl) sentenceCountEl.textContent = sentences.toString();
		
		// Reading Time (Avg 225 wpm)
		const minutes = Math.ceil(words / 225);
		const minAbbr = document.getElementById('copy-btn')?.getAttribute('data-min-abbr') || 'm';
		if (readingTimeEl) readingTimeEl.textContent = `${minutes}${minAbbr}`;
	}

	textInput?.addEventListener('input', updateCounts);

	copyBtn?.addEventListener('click', () => {
		textInput.select();
		navigator.clipboard.writeText(textInput.value);
		const originalHtml = copyBtn.innerHTML;
		const copiedText = copyBtn.getAttribute('data-copied') || '...';
		copyBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check"><polyline points="20 6 9 17 4 12"/></svg> ${copiedText}`;
		setTimeout(() => {
			copyBtn.innerHTML = originalHtml;
		}, 2000);
	});

	clearBtn?.addEventListener('click', () => {
		textInput.value = '';
		updateCounts();
	});
</script>
