---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'id' } },
    { params: { lang: 'es' } },
  ];
}

const { lang: langParam } = Astro.params;
const lang = langParam || 'en';

import ToolLayout from '../../../layouts/ToolLayout.astro';
import PdfMerge from '../../../components/tools/PdfMerge';
import { useTranslations } from '../../../lib/i18n';
const t = useTranslations(lang as any);
---

<ToolLayout 
	title={t('tool.merge.title')}
	description={t('tool.merge.desc')}
	category="pdf"
	toolId="merge"
>
	<PdfMerge client:only="react" lang={lang as any} />

	<div slot="guide">
		<h3>{t('guide.merge.h1')}</h3>
		<ol>
			<li>{t('guide.merge.s1')}</li>
			<li>{t('guide.merge.s2')}</li>
			<li>{t('guide.merge.s3')}</li>
		</ol>

		<h3>{t('guide.merge.h2')}</h3>
		<p>{t('guide.merge.p1')}</p>
	</div>
</ToolLayout>
