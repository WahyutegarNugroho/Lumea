---
import { getI18nPaths } from '../../../lib/routing';
export const getStaticPaths = getI18nPaths;
const { lang: langParam } = Astro.params;
const lang = langParam || 'en';

import ToolLayout from '../../../layouts/ToolLayout.astro';
import PdfRotate from '../../../components/tools/PdfRotate';
import { useTranslations } from '../../../lib/i18n';
const t = useTranslations(lang);
---

<ToolLayout 
	title={t('tool.rotate.title')}
	description={t('tool.rotate.desc')}
	category="pdf"
	toolId="rotate"
>
	<PdfRotate client:only="react" lang={lang} />

	<div slot="guide">
		<h3>{t('guide.rotate.h1')}</h3>
		<p>{t('guide.rotate.p1')}</p>
		
		<h3>{t('guide.rotate.f2_t')}</h3>
		<p>{t('guide.rotate.f2_d')}</p>
	</div>
</ToolLayout>
