---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'id' } },
    { params: { lang: 'es' } },
  ];
}

const { lang: langParam } = Astro.params;
const lang = langParam || 'en';

import ToolLayout from '../../../layouts/ToolLayout.astro';
import PdfToJpg from '../../../components/tools/PdfToJpg';
import { useTranslations } from '../../../lib/i18n';
const t = useTranslations(lang as any);
---

<ToolLayout 
	title={t('tool.pdf-to-jpg.title')}
	description={t('tool.pdf-to-jpg.desc')}
	category="pdf"
	toolId="pdf-to-jpg"
>
	<PdfToJpg client:only="react" lang={lang as any} />

	<div slot="guide">
		<h3>{t('guide.pdf-to-jpg.h1')}</h3>
		<p>{t('guide.pdf-to-jpg.p1')}</p>
		
		<ul>
			<li><strong>{t('guide.pdf-to-jpg.f1_t')}</strong> {t('guide.pdf-to-jpg.f1_d')}</li>
			<li><strong>{t('guide.pdf-to-jpg.f2_t')}</strong> {t('guide.pdf-to-jpg.f2_d')}</li>
			<li><strong>{t('badge.browser_only')}</strong> {t('footer.privacy.desc')}</li>
		</ul>
	</div>
</ToolLayout>
