---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'id' } },
    { params: { lang: 'es' } },
  ];
}

const { lang: langParam } = Astro.params;
const lang = langParam || 'en';

import ToolLayout from '../../../layouts/ToolLayout.astro';
import PdfWatermark from '../../../components/tools/PdfWatermark';
import { useTranslations } from '../../../lib/i18n';
const t = useTranslations(lang as any);
---

<ToolLayout 
	title={t('tool.watermark.title')}
	description={t('tool.watermark.desc')}
	category="pdf"
	toolId="watermark"
>
	<PdfWatermark client:only="react" lang={lang as any} />

	<div slot="guide">
		<h3>{t('guide.watermark.h1')}</h3>
		<p>{t('guide.watermark.p1')}</p>
		
		<ul>
			<li><strong>{t('guide.watermark.f1_t')}</strong> {t('guide.watermark.f1_d')}</li>
			<li><strong>{t('guide.watermark.f2_t')}</strong> {t('guide.watermark.f2_d')}</li>
			<li><strong>{t('badge.browser_only')}</strong> {t('footer.privacy.desc')}</li>
		</ul>
	</div>
</ToolLayout>
