---
import { getI18nPaths } from '../../../lib/routing';
export const getStaticPaths = getI18nPaths;
const { lang: langParam } = Astro.params;
const lang = langParam || 'en';

import ToolLayout from '../../../layouts/ToolLayout.astro';
import PdfToWord from '../../../components/tools/PdfToWord';
import { useTranslations } from '../../../lib/i18n';
const t = useTranslations(lang);
---

<ToolLayout 
	title={t('tool.pdf-to-word.title')}
	description={t('tool.pdf-to-word.desc')}
	category="pdf"
	toolId="pdf-to-word"
>
	<PdfToWord client:only="react" lang={lang} />

	<div slot="guide">
		<h3>{t('guide.pdf-to-word.h1')}</h3>
		<p>{t('guide.pdf-to-word.p1')}</p>
		
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
			<div class="bg-white dark:bg-zinc-900 p-8 rounded-3xl border border-zinc-100 dark:border-zinc-800 shadow-sm">
				<div class="w-12 h-12 bg-zinc-100 dark:bg-zinc-800 rounded-2xl flex items-center justify-center text-zinc-900 dark:text-zinc-50 mb-6">
					<span class="font-bold">01</span>
				</div>
				<h4 class="text-lg font-bold mb-3">{t('guide.pdf-to-word.f1_t')}</h4>
				<p class="text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed">{t('guide.pdf-to-word.f1_d')}</p>
			</div>
			
			<div class="bg-white dark:bg-zinc-900 p-8 rounded-3xl border border-zinc-100 dark:border-zinc-800 shadow-sm">
				<div class="w-12 h-12 bg-zinc-100 dark:bg-zinc-800 rounded-2xl flex items-center justify-center text-zinc-900 dark:text-zinc-50 mb-6">
					<span class="font-bold">02</span>
				</div>
				<h4 class="text-lg font-bold mb-3">{t('guide.pdf-to-word.f2_t')}</h4>
				<p class="text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed">{t('guide.pdf-to-word.f2_d')}</p>
			</div>
			
			<div class="bg-white dark:bg-zinc-900 p-8 rounded-3xl border border-zinc-100 dark:border-zinc-800 shadow-sm">
				<div class="w-12 h-12 bg-zinc-100 dark:bg-zinc-800 rounded-2xl flex items-center justify-center text-zinc-900 dark:text-zinc-50 mb-6">
					<span class="font-bold">03</span>
				</div>
				<h4 class="text-lg font-bold mb-3">{t('guide.pdf-to-word.f3_t')}</h4>
				<p class="text-zinc-500 dark:text-zinc-400 text-sm leading-relaxed">{t('guide.pdf-to-word.f3_d')}</p>
			</div>
		</div>
	</div>
</ToolLayout>
