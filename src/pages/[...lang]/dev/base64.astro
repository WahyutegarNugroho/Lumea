---
import { getI18nPaths } from '../../../lib/routing';
export const getStaticPaths = getI18nPaths;
const { lang: langParam } = Astro.params;
const lang = (langParam || 'en') as string;

import ToolLayout from '../../../layouts/ToolLayout.astro';
import { ArrowLeftRight } from 'lucide-react';
import { useTranslations } from '../../../lib/i18n';
const t = useTranslations(lang);
---

<ToolLayout 
	title={t('tool.base64.title')}
	description={t('tool.base64.desc')}
	category="dev"
	toolId="base64"
>
	<div class="space-y-8">
		<div class="grid grid-cols-1 lg:grid-cols-[1fr,auto,1fr] items-center gap-6">
			<div>
				<label class="tool-label" for="plain-text">{t('ui.normal_text')}</label>
				<textarea 
					id="plain-text" 
				 class="tool-input min-h-[300px] font-mono text-sm" 
					placeholder={t('ui.enter_normal_text')}
				></textarea>
			</div>

			<div class="flex flex-col gap-4">
			<button id="encode-btn" class="tool-button-primary p-3 rounded-full flex items-center justify-center" aria-label="Encode/Decode">
				<ArrowLeftRight size={24} className="rotate-90 lg:rotate-0" />
			</button>
			</div>

			<div>
				<label class="tool-label" for="base64-text">{t('ui.base64_encoded')}</label>
				<textarea 
					id="base64-text" 
				 class="tool-input min-h-[300px] font-mono text-sm" 
					placeholder={t('ui.enter_base64')}
				></textarea>
			</div>
		</div>

		<div class="flex flex-wrap gap-4 pt-4 border-t border-zinc-100 dark:border-zinc-800">
			<button id="clear-btn" class="tool-button-secondary">{t('ui.clear')}</button>
		</div>
	</div>

	<div slot="guide">
		<h3>{t('guide.base64.h1')}</h3>
		<p>{t('guide.base64.p1')}</p>
		
		<ul>
			<li><strong>{t('guide.base64.f1_t')}:</strong> {t('guide.base64.f1_d')}</li>
		</ul>
	</div>
</ToolLayout>

<script>
	window.addEventListener('error', e => console.error('[Tool Error]', e.error || e.message));
	const plainText = document.getElementById('plain-text') as HTMLTextAreaElement;
	const base64Text = document.getElementById('base64-text') as HTMLTextAreaElement;
	const clearBtn = document.getElementById('clear-btn');

	function encode() {
		if (!plainText || !base64Text) return;
		try {
			const str = plainText.value;
			const bytes = new TextEncoder().encode(str);
			const binString = Array.from(bytes, (byte) => String.fromCharCode(byte)).join("");
			base64Text.value = btoa(binString);
		} catch (e) {
			console.error("Encoding failed", e);
		}
	}

	function decode() {
		if (!plainText || !base64Text) return;
		try {
			const binString = atob(base64Text.value);
			const bytes = Uint8Array.from(binString, (m) => m.codePointAt(0) || 0);
			plainText.value = new TextDecoder().decode(bytes);
		} catch (e) {
			console.error("Decoding failed", e);
		}
	}

	plainText?.addEventListener('input', encode);
	base64Text?.addEventListener('input', decode);

	clearBtn?.addEventListener('click', () => {
		if (plainText) plainText.value = '';
		if (base64Text) base64Text.value = '';
	});
</script>
