---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'id' } },
    { params: { lang: 'es' } },
  ];
}

const { lang: langParam } = Astro.params;
const lang = langParam || 'en';

import ToolLayout from '../../../layouts/ToolLayout.astro';
import ColorPicker from '../../../components/tools/ColorPicker';
import { useTranslations } from '../../../lib/i18n';
const t = useTranslations(lang as any);
---

<ToolLayout 
	title={t('tool.color-picker.title')}
	description={t('tool.color-picker.desc')}
	category="dev"
	toolId="color-picker"
>
	<ColorPicker client:only="react" lang={lang as any} />

	<div slot="guide">
		<h3>{t('guide.color-picker.h1')}</h3>
		<p>{t('guide.color-picker.p1')}</p>
	</div>
</ToolLayout>
