---
export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'id' } },
    { params: { lang: 'es' } },
  ];
}

const { lang: langParam } = Astro.params;
const lang = (langParam || 'en') as any;

import ToolLayout from '../../../layouts/ToolLayout.astro';
import { Copy, RefreshCw, Check } from 'lucide-react';
import { useTranslations } from '../../../lib/i18n';
const t = useTranslations(lang as any);
---

<ToolLayout 
	title={t('tool.password-generator.title')}
	description={t('tool.password-generator.desc')}
	category="dev"
	toolId="password-generator"
>
	<div class="space-y-8">
		<div class="bg-zinc-900 rounded-2xl p-8 text-center relative overflow-hidden">
			<div class="absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none">
				<div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white via-transparent to-transparent"></div>
			</div>
			
			<div class="relative z-10">
				<div id="password-display" class="text-2xl md:text-4xl font-mono font-bold text-white break-all mb-6 min-h-[1.5em] flex items-center justify-center">
					••••••••••••••••
				</div>
				
				<div class="flex justify-center gap-4">
					<button id="generate-btn" class="px-6 py-3 bg-white text-zinc-900 rounded-xl font-bold flex items-center gap-2 hover:bg-zinc-100 transition-all">
						<RefreshCw size={18} id="refresh-icon" />
						{t('ui.generate_new')}
					</button>
					<button id="copy-btn" class="px-6 py-3 bg-zinc-800 text-white rounded-xl font-bold flex items-center gap-2 hover:bg-zinc-700 transition-all border border-zinc-700" data-copied={t('ui.copied')}>
						<Copy size={18} />
						{t('ui.copy')}
					</button>
				</div>
			</div>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
			<div class="space-y-6">
				<div>
					<div class="flex justify-between items-center mb-2">
						<label class="tool-label m-0">{t('ui.password_length')}</label>
						<span id="length-val" class="font-bold text-zinc-900">16</span>
					</div>
					<input type="range" id="length" min="4" max="64" value="16" class="w-full accent-zinc-900 h-2 bg-zinc-100 rounded-lg appearance-none cursor-pointer" />
				</div>

				<div class="space-y-3">
					<label class="tool-label">{t('ui.char_sets')}</label>
					<label class="flex items-center gap-3 p-4 bg-zinc-50 border border-zinc-200 rounded-xl cursor-pointer hover:bg-zinc-100 transition-colors">
						<input type="checkbox" id="include-upper" checked class="w-5 h-5 accent-zinc-900" />
						<span class="text-sm font-bold text-zinc-700">{t('ui.uppercase')}</span>
					</label>
					<label class="flex items-center gap-3 p-4 bg-zinc-50 border border-zinc-200 rounded-xl cursor-pointer hover:bg-zinc-100 transition-colors">
						<input type="checkbox" id="include-lower" checked class="w-5 h-5 accent-zinc-900" />
						<span class="text-sm font-bold text-zinc-700">{t('ui.lowercase')}</span>
					</label>
					<label class="flex items-center gap-3 p-4 bg-zinc-50 border border-zinc-200 rounded-xl cursor-pointer hover:bg-zinc-100 transition-colors">
						<input type="checkbox" id="include-numbers" checked class="w-5 h-5 accent-zinc-900" />
						<span class="text-sm font-bold text-zinc-700">{t('ui.numbers')}</span>
					</label>
					<label class="flex items-center gap-3 p-4 bg-zinc-50 border border-zinc-200 rounded-xl cursor-pointer hover:bg-zinc-100 transition-colors">
						<input type="checkbox" id="include-symbols" checked class="w-5 h-5 accent-zinc-900" />
						<span class="text-sm font-bold text-zinc-700">{t('ui.symbols')}</span>
					</label>
				</div>
			</div>

			<div class="p-6 bg-zinc-50 rounded-2xl border border-zinc-100">
				<h4 class="font-bold text-zinc-900 mb-4 flex items-center gap-2">
					<div class="w-6 h-6 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center">
						<Check size={14} />
					</div>
					{t('ui.security_analysis')}
				</h4>
				<ul class="space-y-4 text-sm text-zinc-600">
					<li class="flex items-start gap-3">
						<div class="mt-0.5"><Check size={14} className="text-emerald-500" /></div>
						<span>{t('ui.crypto_api_desc')}</span>
					</li>
					<li class="flex items-start gap-3">
						<div class="mt-0.5"><Check size={14} className="text-emerald-500" /></div>
						<span>{t('ui.entropy_desc')}</span>
					</li>
					<li class="flex items-start gap-3">
						<div class="mt-0.5"><Check size={14} className="text-emerald-500" /></div>
						<span><strong>{t('ui.privacy_promise')}:</strong> {t('ui.privacy_promise_desc')}</span>
					</li>
				</ul>
			</div>
		</div>
	</div>

	<div slot="guide">
		<h3>{t('guide.password-generator.h1')}</h3>
		<p>{t('guide.password-generator.p1')}</p>
		
		<h3>{t('guide.password-generator.h2')}</h3>
		<p>{t('guide.password-generator.p2')}</p>
	</div>
</ToolLayout>

<script>
	const passwordDisplay = document.getElementById('password-display');
	const generateBtn = document.getElementById('generate-btn');
	const copyBtn = document.getElementById('copy-btn');
	const lengthInput = document.getElementById('length') as HTMLInputElement;
	const lengthVal = document.getElementById('length-val');
	const includeUpper = document.getElementById('include-upper') as HTMLInputElement;
	const includeLower = document.getElementById('include-lower') as HTMLInputElement;
	const includeNumbers = document.getElementById('include-numbers') as HTMLInputElement;
	const includeSymbols = document.getElementById('include-symbols') as HTMLInputElement;
	const refreshIcon = document.getElementById('refresh-icon');

	const CHAR_SETS = {
		upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
		lower: 'abcdefghijklmnopqrstuvwxyz',
		numbers: '0123456789',
		symbols: '!@#$%^&*()_+-=[]{}|;:,.<>?'
	};

	function generatePassword() {
		let chars = '';
		if (includeUpper.checked) chars += CHAR_SETS.upper;
		if (includeLower.checked) chars += CHAR_SETS.lower;
		if (includeNumbers.checked) chars += CHAR_SETS.numbers;
		if (includeSymbols.checked) chars += CHAR_SETS.symbols;

		if (!chars) chars = CHAR_SETS.lower;

		const length = parseInt(lengthInput.value);
		const array = new Uint32Array(length);
		window.crypto.getRandomValues(array);

		let password = '';
		for (let i = 0; i < length; i++) {
			password += chars[array[i] % chars.length];
		}

		if (passwordDisplay) passwordDisplay.textContent = password;
		
		refreshIcon?.classList.add('animate-spin');
		setTimeout(() => refreshIcon?.classList.remove('animate-spin'), 500);
	}

	lengthInput?.addEventListener('input', () => {
		if (lengthVal) lengthVal.textContent = lengthInput.value;
		generatePassword();
	});

	[includeUpper, includeLower, includeNumbers, includeSymbols].forEach(cb => {
		cb.addEventListener('change', generatePassword);
	});

	generateBtn?.addEventListener('click', generatePassword);

	copyBtn?.addEventListener('click', () => {
		const password = passwordDisplay?.textContent;
		if (password) {
			navigator.clipboard.writeText(password);
			const originalContent = copyBtn.innerHTML;
			const copiedText = copyBtn.getAttribute('data-copied') || '...';
			copyBtn.innerHTML = copiedText;
			setTimeout(() => {
				copyBtn.innerHTML = originalContent;
			}, 2000);
		}
	});

	// Initial generate
	generatePassword();
</script>
