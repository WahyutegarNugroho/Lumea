---
import '../styles/global.css';
import lucide from 'lucide-react';
const { ShieldCheck, Mail } = lucide;
import { ClientRouter } from 'astro:transitions';
import CommandPalette from '../components/ui/CommandPalette.astro';
import LanguagePicker from '../components/ui/LanguagePicker.astro';
import { useTranslations, type Locale, getLocalizedPath } from '../lib/i18n';

const lang = (Astro.currentLocale || 'en') as Locale;
const t = useTranslations(lang);

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = t('site.title'), 
	description = t('site.description') 
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="theme-color" content="#09090b" />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700&display=swap" rel="stylesheet">
		
		<ClientRouter />
	</head>
	<body class="bg-zinc-50 text-zinc-900 font-sans min-h-screen flex flex-col">
		<header class="sticky top-0 z-50 w-full border-b border-zinc-200 bg-white/80 backdrop-blur-md">
			<div class="container mx-auto px-4 h-16 flex items-center">
				<!-- Logo Section -->
				<div class="flex-1 flex items-center">
					<a href={getLocalizedPath('/', lang)} class="flex items-center gap-2 group">
						<div class="w-8 h-8 bg-zinc-900 rounded-lg flex items-center justify-center transition-transform group-hover:scale-105">
							<span class="text-white font-bold text-xl leading-none">L</span>
						</div>
						<span class="text-xl font-bold font-outfit tracking-tight">Lumea</span>
					</a>
				</div>
				
				<!-- Nav Section (Centered) -->
				<nav class="hidden md:flex items-center justify-center gap-8">
					<a href={getLocalizedPath('/', lang)} class="text-sm font-bold text-zinc-600 hover:text-zinc-900 transition-colors uppercase tracking-widest">{t('nav.home')}</a>
					<a href={getLocalizedPath('/#pdf', lang)} class="text-sm font-bold text-zinc-600 hover:text-zinc-900 transition-colors uppercase tracking-widest">{t('nav.tools')}</a>
					<a href={getLocalizedPath('/blog', lang)} class="text-sm font-bold text-zinc-600 hover:text-zinc-900 transition-colors uppercase tracking-widest">{t('nav.blog')}</a>
				</nav>

				<!-- Right Section -->
				<div class="flex-1 flex items-center justify-end gap-4">
					<LanguagePicker />
					<button id="search-trigger" class="flex items-center gap-2 px-3 py-1.5 bg-zinc-100 hover:bg-zinc-200 text-zinc-500 rounded-lg text-xs font-medium transition-colors border border-zinc-200">
						<kbd class="font-sans">Ctrl+K</kbd>
						<span>{t('nav.tools')}</span>
					</button>
					<div class="hidden lg:flex items-center gap-1.5 px-3 py-1.5 bg-emerald-50 text-emerald-700 rounded-full border border-emerald-100 text-xs font-medium">
						<ShieldCheck size={14} />
						{t('ui.client_side')}
					</div>
				</div>
			</div>
		</header>

		<CommandPalette />

		<main class="flex-grow">
			<slot />
		</main>

		<footer class="border-t border-zinc-200 bg-white py-12">
			<div class="container mx-auto px-4">
				<div class="grid grid-cols-1 md:grid-cols-4 gap-8">
					<div class="col-span-1 md:col-span-2">
						<div class="flex items-center gap-2 mb-4">
							<div class="w-8 h-8 bg-zinc-900 text-white rounded-lg flex items-center justify-center font-bold font-outfit">L</div>
							<span class="text-xl font-bold font-outfit text-zinc-900 tracking-tight">Lumea</span>
						</div>
						<p class="text-zinc-500 text-sm leading-relaxed mb-6">
							{t('footer.privacy.desc')}
						</p>
						<div class="flex items-center gap-2 text-zinc-400">
							<ShieldCheck size={16} />
							<span class="text-xs font-medium uppercase tracking-wider">{t('ui.privacy_first_arch')}</span>
						</div>
					</div>
					
					<div>
						<h4 class="font-bold text-zinc-900 mb-6 uppercase tracking-widest text-xs">{t('footer.tools')}</h4>
						<ul class="space-y-4 text-sm text-zinc-500">
							<li><a href={getLocalizedPath('/pdf/merge', lang)} class="hover:text-zinc-900 transition-colors">{t('tool.merge.title')}</a></li>
							<li><a href={getLocalizedPath('/image/compressor', lang)} class="hover:text-zinc-900 transition-colors">{t('tool.compressor.title')}</a></li>
							<li><a href={getLocalizedPath('/dev/password-generator', lang)} class="hover:text-zinc-900 transition-colors">{t('tool.password-generator.title')}</a></li>
						</ul>
					</div>

					<div>
						<h4 class="font-bold text-zinc-900 mb-6 uppercase tracking-widest text-xs">{t('footer.company')}</h4>
						<ul class="space-y-4 text-sm text-zinc-500">
							<li><a href={getLocalizedPath('/blog', lang)} class="hover:text-zinc-900 transition-colors">{t('nav.blog')}</a></li>
							<li><a href="#" class="hover:text-zinc-900 transition-colors">{t('nav.about')}</a></li>
						</ul>
					</div>
				</div>
				
				<div class="mt-12 pt-8 border-t border-zinc-100 flex flex-col md:flex-row justify-between items-center gap-4">
					<p class="text-zinc-400 text-sm">
						&copy; {new Date().getFullYear()} Lumea. {t('ui.footer_copyright')}
					</p>
					<div class="flex items-center gap-6">
						<a href="mailto:wahyutgrss@gmail.com" class="text-zinc-400 hover:text-zinc-600 transition-colors">
							<span class="sr-only">Email</span>
							<Mail size={20} />
						</a>
						<a href="https://github.com/WahyutegarNugroho" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-zinc-600 transition-colors">
							<span class="sr-only">GitHub</span>
							<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
						</a>
					</div>
				</div>
			</div>
		</footer>
		<script is:inline>
			// FORCE HARD RESET OF ALL SERVICE WORKERS AND CACHES
			if ('serviceWorker' in navigator) {
				navigator.serviceWorker.getRegistrations().then(registrations => {
					for(let registration of registrations) registration.unregister();
				});
			}
			if ('caches' in window) {
				caches.keys().then(names => {
					for (let name of names) caches.delete(name);
				});
			}

			// Auto-detect language on first visit
			if (!localStorage.getItem('lumea_lang_detected') && window.location.pathname === '/') {
				const browserLang = navigator.language.split('-')[0];
				const supported = ['id', 'es'];
				if (supported.includes(browserLang)) {
					localStorage.setItem('lumea_lang_detected', 'true');
					window.location.href = `/${browserLang}/`;
				}
			}

			// FORCE UNREGISTER SERVICE WORKER TO FIX DOWNLOAD ISSUES
			if ('serviceWorker' in navigator) {
				navigator.serviceWorker.getRegistrations().then(function(registrations) {
					for(let registration of registrations) {
						registration.unregister();
						console.log('SW Unregistered for stability');
					}
				});
			}

			/*
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/sw.js').then(registration => {
						console.log('SW registered: ', registration);
					}).catch(registrationError => {
						console.log('SW registration failed: ', registrationError);
					});
				});
			}
			*/
		</script>
	</body>
</html>

<style is:global>
	:root {
		--font-sans: 'Inter', system-ui, -apple-system, sans-serif;
		--font-outfit: 'Outfit', 'Inter', system-ui, sans-serif;
	}
	
	html {
		scroll-behavior: smooth;
	}

	body {
		font-family: var(--font-sans);
	}

	.font-outfit {
		font-family: var(--font-outfit);
	}
</style>
