---
import BaseLayout from './BaseLayout.astro';
import { ShieldCheck, Info, ArrowLeft } from 'lucide-react';

interface Props {
	title: string;
	description: string;
	category: string;
	toolId?: string;
}

const { title, description, category, toolId } = Astro.props;

import { FavoriteButton } from '../components/ui/FavoriteButton';
import { useTranslations, getLocaleFromPath, getLocalizedPath } from '../lib/i18n';
const lang = getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(lang);

import { getCollection, render } from 'astro:content';
const guides = await getCollection('guides');
const guide = toolId ? guides.find((g: { data: { toolId: string } }) => g.data.toolId === toolId) : null;
const rendered = guide ? await render(guide) : null;
const Content = rendered?.Content;
---

<BaseLayout title={`${title} - Lumea Tools`} description={description}>
	<script is:inline type="application/ld+json" define:vars={{ title, description, category }}>
		{
			"@context": "https://schema.org",
			"@type": "SoftwareApplication",
			"name": title,
			"description": description,
			"applicationCategory": category,
			"operatingSystem": "Web",
			"offers": {
				"@type": "Offer",
				"price": "0",
				"priceCurrency": "USD"
			}
		}
	</script>
	<div class="container mx-auto px-4 py-12">
		<!-- Back to Home -->
		<a href={getLocalizedPath('/', lang)} class="inline-flex items-center gap-2 text-sm font-bold text-zinc-400 dark:text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-50 transition-colors mb-4 uppercase tracking-widest">
			<ArrowLeft size={16} />
			{t('nav.home')}
		</a>

		<!-- Breadcrumbs -->
		<nav class="flex mb-8 text-sm font-medium text-zinc-500 dark:text-zinc-400" aria-label="Breadcrumb">
			<ol class="flex items-center space-x-2">
				<li><a href={getLocalizedPath('/', lang)} class="hover:text-zinc-900 dark:hover:text-zinc-50 transition-colors">{t('nav.home')}</a></li>
				<li><span class="px-1">/</span></li>
				<li class="capitalize">{t(`cat.${category}`) || category}</li>
				<li><span class="px-1">/</span></li>
				<li class="text-zinc-900 dark:text-zinc-50">{t(`tool.${toolId}.title`) || title}</li>
			</ol>
		</nav>

		<div class="max-w-5xl mx-auto">
			<!-- Header -->
			<div class="mb-10 text-center md:text-left">
				<div class="flex items-center justify-center md:justify-start gap-4 mb-4">
					<h1 class="text-4xl font-bold font-outfit text-zinc-900 dark:text-zinc-50 m-0">{t(`tool.${toolId}.title`) || title}</h1>
					{toolId && <FavoriteButton client:only="react" toolId={toolId} />}
				</div>
				<p class="text-lg text-zinc-500 dark:text-zinc-400 max-w-2xl">{t(`tool.${toolId}.desc`) || description}</p>
				
				<div class="mt-6 flex flex-wrap gap-4 justify-center md:justify-start">
					<div class="flex items-center gap-1.5 px-3 py-1.5 bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 rounded-full border border-emerald-100 dark:border-emerald-800 text-xs font-medium">
						<ShieldCheck size={14} />
						{t('ui.secure')}
					</div>
				</div>
			</div>

			<!-- Tool Interface -->
			<div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-3xl shadow-sm overflow-hidden mb-16">
				<div id="tool-container" class="p-6 md:p-8">
					<slot />
				</div>
			</div>

			<!-- SEO Guide Area -->
			<div class="prose prose-zinc dark:prose-invert max-w-none border-t border-zinc-100 dark:border-zinc-900 pt-16 pb-24">
				<div class="flex items-center gap-2 mb-8 text-zinc-500 dark:text-zinc-400">
					<Info size={20} />
					<h2 class="text-xl font-bold font-outfit text-zinc-900 dark:text-zinc-50 m-0">{t('ui.how_to')} {t(`tool.${toolId}.title`) || title}</h2>
				</div>
				<slot name="guide">
					{Content ? <Content /> : <p>{t('ui.guide_coming_soon')} {title}.</p>}
				</slot>
			</div>
		</div>
	</div>
</BaseLayout>

<script is:inline define:vars={{ toolId }} data-astro-rerun>
	if (toolId) {
		const STORAGE_KEY = 'recent_tools';
		const MAX = 6;
		try {
			const recent = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
			const updated = [toolId, ...recent.filter((id) => id !== toolId)].slice(0, MAX);
			localStorage.setItem(STORAGE_KEY, JSON.stringify(updated));
		} catch {}
	}
</script>


